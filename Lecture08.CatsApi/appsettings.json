{
    "ConnectionStrings": {
        "CatsDb": "Host=localhost;Port=5432;Database=cats_db_local;Username=postgres;Password=postgres"
    },

    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Information"
            }
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Level:u3}] {Message:lj} {NewLine}{Exception}"
                }
            }
        ]
    },

    "AllowedHosts": "*"
}
